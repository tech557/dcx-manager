{
  "name": "dcx-manager-v0.3.5",
  "private": true,
  "version": "0.3.5",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --max-warnings 0",
    "validate:architecture": "depcruise src --config .dependency-cruiser.cjs",
    "scan:semgrep": "bash scripts/agent/run-semgrep.sh",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "inspect:react": "npx react-scan@latest http://localhost:3000",
    "verify:frontend": "npm run typecheck && npm run lint && bash scripts/verify.sh && npm run validate:architecture",
    "generate:code-index": "node --experimental-strip-types scripts/generate-code-index.ts",
    "req:validate": "node --experimental-strip-types scripts/requirements/validate.ts",
    "req:propose": "node --experimental-strip-types scripts/requirements/propose.ts",
    "req:apply-after-signoff": "node --experimental-strip-types scripts/requirements/apply-after-signoff.ts",
    "req:generate-views": "node --experimental-strip-types scripts/requirements/generate-views.ts",
    "req:query": "node --experimental-strip-types scripts/requirements/query.ts",
    "req:trace": "node --experimental-strip-types scripts/requirements/trace.ts",
    "req:justify": "node --experimental-strip-types scripts/requirements/justify.ts",
    "req:reconcile": "node --experimental-strip-types scripts/requirements/reconcile.ts",
    "req:refresh-code-index": "npm run generate:code-index",
    "req:completion-gate": "node --experimental-strip-types scripts/requirements/completion-gate.ts",
    "req:seed-rs-r6": "node --experimental-strip-types scripts/requirements/seed-rs-r6.ts",
    "req:persist-rs-r7": "node --experimental-strip-types scripts/requirements/persist-rs-r7-review-queue.ts",
    "req:normalize-rs-r7-identities": "node --experimental-strip-types scripts/requirements/normalize-rs-r7-identities.ts",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "req:folder-index": "node --experimental-strip-types scripts/requirements/folder-index.ts",
    "req:seed-evidence-rs-r8": "node --experimental-strip-types scripts/requirements/seed-evidence-rs-r8.ts",
    "req:seed-rs-r9": "node --experimental-strip-types scripts/requirements/seed-rs-r9.ts"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.9",
    "@google/genai": "^1.29.0",
    "@supabase/supabase-js": "^2.110.0",
    "@tailwindcss/vite": "^4.1.14",
    "@tanstack/react-query": "^5.101.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "gsap": "^3.15.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "radix-ui": "^1.6.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-router-dom": "^7.6.3",
    "shadcn": "^4.12.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.2.1",
    "@eslint/js": "^9.39.4",
    "@playwright/mcp": "^0.0.77",
    "@playwright/test": "^1.61.1",
    "@storybook/addon-a11y": "^10.4.6",
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/addon-mcp": "^0.6.0",
    "@storybook/react-vite": "^10.4.6",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.0.4",
    "dependency-cruiser": "^18.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-storybook": "^10.4.6",
    "jsdom": "^29.1.1",
    "playwright": "^1.61.1",
    "storybook": "^10.4.6",
    "tailwindcss": "^4.1.14",
    "ts-morph": "^28.0.0",
    "typescript": "~5.8.2",
    "typescript-eslint": "^8.62.0",
    "vite": "^6.2.3",
    "vitest": "^1.0.0"
  }
}
